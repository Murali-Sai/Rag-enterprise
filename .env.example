# LLM Provider: groq | gemini | huggingface | openai
LLM_PROVIDER=groq

# API Keys (get free keys from respective providers)
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Vector Store: chroma | opensearch
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./chroma_data

# Auth
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Database
DATABASE_URL=sqlite+aiosqlite:///./rag_enterprise.db

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# Rate Limiting
RATE_LIMIT=20/minute

# SEC EDGAR (free, no API key needed — only requires User-Agent)
EDGAR_USER_AGENT=YourName your.email@example.com
EDGAR_DATA_DIR=./data/edgar
